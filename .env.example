# ─── OBRIGATÓRIO ─────────────────────────────────────────────────
# Chave da API do Anthropic (Claude)
# Obter em: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── OPCIONAL ────────────────────────────────────────────────────
# Chave de acesso do Unsplash (para imagens de fundo)
# Cadastro gratuito em: https://unsplash.com/developers
# Limite: 50 requisições/hora no plano gratuito
UNSPLASH_ACCESS_KEY=

# Chave Pexels (imagens de fundo — preferido ao Unsplash)
# Cadastro gratuito em: https://www.pexels.com/api/
PEXELS_API_KEY=

# ─── INSTAGRAM (publicação automática) ───────────────────────────
# Long-lived access token da Instagram Graph API (60 dias)
# Gerar em: developers.facebook.com → app → "Gerenciar mensagens e conteúdo no Instagram" → Generate token
# Refresh antes de expirar:
#   curl "https://graph.instagram.com/v22.0/refresh_access_token?grant_type=ig_refresh_token&access_token=TOKEN"
INSTAGRAM_ACCESS_TOKEN=

# ID numérico da conta Instagram Business conectada
# Buscar em: developers.facebook.com → API setup with Instagram business login
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ─── SERVIDOR ────────────────────────────────────────────────────
PORT=8000
