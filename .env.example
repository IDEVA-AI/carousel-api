# ─── OBRIGATÓRIO ─────────────────────────────────────────────────
# Chave da API do Anthropic (Claude)
# Obter em: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── OPCIONAL ────────────────────────────────────────────────────
# Chave de acesso do Unsplash (para imagens de fundo)
# Cadastro gratuito em: https://unsplash.com/developers
# Limite: 50 requisições/hora no plano gratuito
UNSPLASH_ACCESS_KEY=

# Chave Pexels (imagens de fundo — preferido ao Unsplash)
# Cadastro gratuito em: https://www.pexels.com/api/
PEXELS_API_KEY=

# ─── SERVIDOR ────────────────────────────────────────────────────
PORT=8000
